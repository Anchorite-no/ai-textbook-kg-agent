# 前端开发环境变量
# 复制本文件为 .env.development（已在 .gitignore），按需调整。

# 后端 API 地址（dev 模式下 vite proxy 也会转发 /api 到后端）
VITE_API_BASE_URL=http://127.0.0.1:8010

# 各域 API 模式：live=直连后端，mock=本地 fixture（plan 17 §5）
VITE_API_TEXTBOOKS=live
VITE_API_GRAPH=mock
VITE_API_INTEGRATION=mock
VITE_API_RAG=mock
VITE_API_DIALOGUE=mock
VITE_API_REPORT=mock
